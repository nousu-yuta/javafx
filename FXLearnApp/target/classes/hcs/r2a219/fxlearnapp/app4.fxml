<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="576.0" prefWidth="320.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="hcs.r2a219.fxlearnapp.controller.App4Controller">
    <children>
        <ImageView layoutX="0.0" layoutY="65.0" fitHeight="480.0" fitWidth="320.0"  pickOnBounds="true">
            <image>
                <Image url="@../../../image/fruits.png" />
            </image>
        </ImageView>
        <Button layoutX="12.0" layoutY="12.0" mnemonicParsing="false" onAction="#pushBackButton" text="◀" />
        <Label alignment="CENTER" layoutX="60.0" layoutY="10.0" prefHeight="27.0" prefWidth="200.0" text="App4">
            <font>
                <Font size="20.0" />
            </font>
        </Label>
        <ImageView fx:id="image" fitHeight="120.0" fitWidth="120.0" layoutX="175.0" layoutY="220.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../../../image/before.png" />
            </image></ImageView>
        <Button layoutX="195.0" layoutY="100.0" mnemonicParsing="false" onAction="#beforeClick" prefHeight="30.0" prefWidth="80.0" text="Before" />
        <Button layoutX="195.0" layoutY="150.0" mnemonicParsing="false" onAction="#afterClick" prefHeight="30.0" prefWidth="80.0" text="After" />
        <Button layoutX="220.0" layoutY="390.0" mnemonicParsing="false" onAction="#up" prefHeight="30.0" prefWidth="30.0" text="▲" />
        <Button layoutX="220.0" layoutY="450.0" mnemonicParsing="false" onAction="#down" prefHeight="30.0" prefWidth="30.0" text="▼" />
        <Button layoutX="190.0" layoutY="420.0" mnemonicParsing="false" onAction="#left" prefHeight="30.0" prefWidth="30.0" text="◀" />
        <Button layoutX="250.0" layoutY="420.0" mnemonicParsing="false" onAction="#right" prefHeight="30.0" prefWidth="30.0" text="▶" />
        <Button layoutX="195.0" layoutY="500.0" mnemonicParsing="false" onAction="#reset" prefHeight="30.0" prefWidth="80.0" text="reset" />

    </children>
</AnchorPane>
